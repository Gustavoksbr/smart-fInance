# =============================================================================
# Variáveis de Ambiente - Backend
# =============================================================================

# Chave secreta para JWT (gere uma nova em produção)
# Para gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# URL do banco de dados
# PostgreSQL (recomendado para produção):
DATABASE_URL=postgresql://user:password@localhost:5432/smartfinance

# SQLite (desenvolvimento - comente a linha acima e descomente abaixo):
# DATABASE_URL=sqlite:///./smartfinance.db

# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# URL do próprio backend (para keep-alive)
# Em produção, configure com a URL do deploy (ex: https://sua-api.onrender.com)
BACKEND_URL=http://localhost:8000

# =============================================================================
# Chave de API para o Assistente LLM (Bate-papo com IA)
# =============================================================================

# Opção 1: Usar Groq (recomendado para desenvolvimento)
# 1. Acesse: https://console.groq.com
# 2. Crie uma API key
# 3. Cole aqui:
API_KEY=your-groq-api-key-here
LLM_API_URL=https://api.groq.com/v1/models/llama-3.1-8b-instant/predict

# Opção 2: Usar OpenAI (substitua API_KEY e LLM_API_URL)
# API_KEY=sk-proj-xxxxx
# LLM_API_URL=https://api.openai.com/v1/chat/completions